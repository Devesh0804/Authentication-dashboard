<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/signup.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
   <div class="signupForm">
     <h2>Create Account</h2>
        <h5>Create your account</h5>
       <form action="/signup" class="form" method="post">
        <div class="input-wrapper">
         <i class="fa-solid fa-user"></i>
        <input type="text" name="username" id="" placeholder="Full Name " >
        </div>
        <div class="input-wrapper">
         <i class="fa-solid fa-envelope"></i>
        <input type="email" name="user_email" id="" placeholder="Email id">
        </div>
        <div class="input-wrapper">
        <i class="fa-solid fa-lock"></i>
        <input type="password" name="userpassword" id="" placeholder="Password">
        </div>
       
          <div class="google-wrap">

            <i class="fa-brands fa-google"></i>
       <a href="/auth/google" class="google">Google</a>
       </div>
        <button class="main-button"`>Signup</button>
        <a href="/login" class="login">already have an Account ? Login</a>
        
        <p><%= message %></p>
       </form>
   </div>
</body>
</html>