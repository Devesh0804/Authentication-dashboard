<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/signup.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
   <div class="signupForm">

        <h2>Login your Account</h2>
       <form action="/login" class="form" method="post">
       
       <div class="input-wrapper">
          <i class="fa-solid fa-envelope"></i>
        <input type="email" name="user_email" id="" placeholder="Email id">
        </div>
        <div class="input-wrapper">
            <i class="fa-solid fa-lock"></i>
        <input type="password" name="userpassword" id="" placeholder="Password">
        </div>
        <button class="main-button">Login</button>
        <div class="google-wrap">
            <i class="fa-brands fa-google"></i>
       <a href="/auth/google" class="google">Google</a>
       </div>
       <a href="/" class="signup">Not have an Account Signup</a>
       <p><%= message %></p>
        
       </form>
   </div>
</body>
</html>