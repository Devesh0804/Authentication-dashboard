<%- include('navbar') %>
 
<center>
    
<% if(data.length > 0) { %>
    
    <% data.map((values )=>{ %>
    
       
        <% if(values !== "" ) { %>
          <table class="table" align="center">
  <thead align="center">
    <tr>
      <th scope="col">Sid</th>
      <th scope="col">Name</th>
      <th scope="col">User Email</th>
      <th scope="col">buttons</th>
    </tr>
  </thead>
  <tbody class="table-group-divider" align="center">
    <tr>
      <th scope="row"><%= values._id %></th>
      <td><%= values.username %></td>
      <td><%= values.user_email %></td>
   
      <td>
        <a type="button" href="/crudRoutes/update/<%= values._id %>" class="btn btn-outline-info mx-auto">Update</a>
        <a type="button" href="/crudRoutes/delete/<%= values._id%>" class="btn btn-outline-primary mx-auto">Delete</a>
        <a type="button" href="/crudRoutes/view/<%= values._id %>" class="btn btn-outline-dark mx-auto">Read</a>
        <a type="button" href="/crudRoutes/image/<%= values._id %>" class="btn btn-outline-dark mx-auto">Image</a></td> 
      </tr>
            <% }  else { %>
            
              <center>
                <h1><%= key %> Not Found !!</h1>
                </center>
            <% } %>
    <% }) %>
    <% }  else { %>
    
        <center>
          <h1><%= key %> Not Found !!</h1>
        </center>
      <% } %>
  </tbody>
</table>
</center>
<%- include('footer') %>